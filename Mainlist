package com.example.training

import android.os.Bundle
import android.widget.Button
import android.widget.EditText
import android.widget.LinearLayout
import androidx.appcompat.app.AlertDialog
import androidx.appcompat.app.AppCompatActivity

class Mainlist : AppCompatActivity() {

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_mainlist)

        val viewData = findViewById<Button>(R.id.view_data)
        val updateBtn = findViewById<Button>(R.id.update)
        val deleteBtn = findViewById<Button>(R.id.delete)

        val dbHelper = DBHelper(this)


        viewData.setOnClickListener {

            val cursor = dbHelper.getData()

            if (cursor.count == 0) {
                AlertDialog.Builder(this)
                    .setTitle("Data")
                    .setMessage("No Data Found")
                    .setPositiveButton("OK", null)
                    .show()
            } else {

                val buffer = StringBuilder()

                while (cursor.moveToNext()) {
                    buffer.append("Username: ${cursor.getString(0)}\n")
                    buffer.append("Email: ${cursor.getString(1)}\n")
                    buffer.append("Password: ${cursor.getString(2)}\n\n")
                }

                AlertDialog.Builder(this)
                    .setTitle("Registered Users")
                    .setMessage(buffer.toString())
                    .setPositiveButton("OK", null)
                    .show()
            }

            cursor.close()
        }


        updateBtn.setOnClickListener {

            val layout = LinearLayout(this)
            layout.orientation = LinearLayout.VERTICAL

            val usernameEt = EditText(this)
            usernameEt.hint = "Enter Username"

            val emailEt = EditText(this)
            emailEt.hint = "Enter New Email"

            val passwordEt = EditText(this)
            passwordEt.hint = "Enter New Password"

            layout.addView(usernameEt)
            layout.addView(emailEt)
            layout.addView(passwordEt)

            AlertDialog.Builder(this)
                .setTitle("Update User")
                .setView(layout)
                .setPositiveButton("Update") { _, _ ->

                    val username = usernameEt.text.toString()
                    val email = emailEt.text.toString()
                    val password = passwordEt.text.toString()

                    val isUpdated = dbHelper.updateData(
                        username,
                        email,
                        password
                    )

                    if (isUpdated) {
                        AlertDialog.Builder(this)
                            .setTitle("Success")
                            .setMessage("Data Updated Successfully")
                            .setPositiveButton("OK", null)
                            .show()
                    } else {
                        AlertDialog.Builder(this)
                            .setTitle("Error")
                            .setMessage("Username Not Found")
                            .setPositiveButton("OK", null)
                            .show()
                    }
                }
                .setNegativeButton("Cancel", null)
                .show()
        }


        deleteBtn.setOnClickListener {

            val usernameEt = EditText(this)
            usernameEt.hint = "Enter Username to Delete"

            AlertDialog.Builder(this)
                .setTitle("Delete User")
                .setView(usernameEt)
                .setPositiveButton("Delete") { _, _ ->

                    val username = usernameEt.text.toString()

                    val isDeleted = dbHelper.deleteData(username)

                    if (isDeleted) {
                        AlertDialog.Builder(this)
                            .setTitle("Success")
                            .setMessage("User Deleted Successfully")
                            .setPositiveButton("OK", null)
                            .show()
                    } else {
                        AlertDialog.Builder(this)
                            .setTitle("Error")
                            .setMessage("Username Not Found")
                            .setPositiveButton("OK", null)
                            .show()
                    }
                }
                .setNegativeButton("Cancel", null)
                .show()
        }
    }
}
